---
// ProjectCard.astro
---

<div class="project-card">
  <h2>项目</h2>
  <ul class="highlight-list">
    <li><span>☆</span> Abyssal Puzzle 项目组成员</li>
    <li><span>☆</span> 学生休闲开发者</li>
  </ul>
  
  <h3>目前参与项目</h3>
  <ul class="project-items">
    <li class="item">
      <a href="https://github.com/HaiHomeQwQ/Webmatica" target="_blank">
        <img src="https://github.githubassets.com/favicons/favicon.svg" alt="GitHub" />
        HaiHomeQwQ/Webmatica
        <span class="arrow">→</span>
      </a>
    </li>
    <li class="item">
      <a href="https://github.com/HaiHomeQwQ/haihome.page" target="_blank">
        <img src="https://github.githubassets.com/favicons/favicon.svg" alt="GitHub" />
        HaiHomeQwQ/haihome.page
        <span class="arrow">→</span>
      </a>
    </li>
    <li class="item">
      <a href="https://github.com/abyssal-puzzle-team/ap-rewind" target="_blank">
        <img src="https://github.githubassets.com/favicons/favicon.svg" alt="GitHub" />
        abyssal-puzzle-team/ap-rewind
        <span class="arrow">→</span>
      </a>
    </li>
    <li class="item">
      <a href="https://github.com/BrokenLandSMP/website" target="_blank">
        <img src="https://github.githubassets.com/favicons/favicon.svg" alt="GitHub" />
        BrokenLandSMP/website
        <span class="arrow">→</span>
      </a>
    </li>
  </ul>
</div>

<style>
  .project-card {
    background: var(--bg-card);
    border-radius: var(--radius);
    padding: 24px;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-height: 550px;
  }

  h2 { font-size: 1.5rem; color: var(--text-primary); margin: 0; }
  h3 { font-size: 1.1rem; color: var(--text-secondary); margin: 8px 0 0 0; }

  .highlight-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    color: var(--text-secondary);
  }
  
  .highlight-list li { display: flex; align-items: center; gap: 8px; }
  .highlight-list span { color: #facc15; }

  .project-items {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .item {
    height: 48px;
    background: var(--bg-page);
    border-radius: calc(var(--radius) / 2);
    display: flex;
    align-items: center;
  }

  .item a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 0 16px;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .item a:hover {
    background: var(--bg-card); /* 稍微调整悬停颜色 */
    transform: translateX(4px);
  }

  .item img {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .arrow {
    margin-left: auto;
    font-weight: bold;
    color: var(--text-secondary);
  }
</style>
