---
// AboutCard.astro
---

<div class="about-card">
  <h2>关于我</h2>
  <div class="content">
    <slot />
  </div>
</div>

<style>
  .about-card {
    background: var(--bg-card);
    border-radius: var(--radius);
    padding: 32px;
    box-shadow: var(--shadow);
    width: 100%;
    box-sizing: border-box;
  }
  h2 { font-size: 2rem; color: var(--text-primary); margin-bottom: 24px; }
  .content { color: var(--text-primary); line-height: 1.6; font-size: 1.1rem; }
</style>