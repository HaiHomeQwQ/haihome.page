---
// TopCard.astro
---

<div class="saying-card">
  <div class="date">
    <span class="day">19</span>
    <span class="separator">/</span>
    <span class="month">Jul.</span>
  </div>
  <div class="content">
    <p class="text">We do not remember days, we remember moments.</p>
    <p class="author">--Cesare Pavese</p>
  </div>
</div>

<style>
  .saying-card {
    background: var(--bg-card);
    border-radius: var(--radius);
    padding: 32px 40px; /* 增加内边距 */
    box-shadow: var(--shadow);
    display: flex;
    align-items: center;
    gap: 32px; /* 增加左右间距 */
    margin-bottom: 20px;
  }

  .date {
    display: flex;
    align-items: baseline;
    gap: 8px; /* 元素间距 */
    white-space: nowrap;
    border-right: 1px solid var(--text-secondary);
    padding-right: 32px;
  }

  .day { 
    font-size: 2.5rem; 
    font-weight: 600;
    color: var(--text-primary);
  }
  
  .separator { 
    font-size: 1.5rem;
    color: var(--text-secondary);
    font-weight: 300;
  }
  
  .month { 
    font-size: 1.5rem; 
    font-weight: 600;
    color: var(--text-primary);
  }

  .content {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-start;
    height: 100%;
  }

  .text { 
    font-size: 1.25rem; 
    color: var(--text-primary); 
    line-height: 1.2;
    margin: 0;
  }
  
  .author { 
    color: var(--text-secondary); 
    font-size: 0.9rem;
    white-space: nowrap;
    margin: 0;
    align-self: flex-end;
  }
  @media (max-width: 768px) {
    .date {
      display: none;
    }
  }
</style>
