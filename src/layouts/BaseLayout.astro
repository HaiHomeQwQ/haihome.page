---
export interface Props {
  title: string;
}

const { title } = Astro.props;
import '../styles/global.css';
import '../fonts/xiaolai/xiaolai.css';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { ClientRouter } from 'astro:transitions';
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preload" href="/fonts/xiaolai/363165d89075367554ce6d4cef6a8c19.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <ClientRouter />
  </head>
  <body>
      <div class="background-animation" transition:persist></div>
      <div class="sidebar-shell" transition:persist>
        <Sidebar />
      </div>
      <main transition:name="page-content">
        <slot />
        <Footer />
      </main>
      <Analytics />
      <SpeedInsights />
  </body>
  <script>
    const container = document.querySelector('.background-animation');
    if (container) {
      const count = 50;
      for (let i = 0; i < count; i++) {
        const flake = document.createElement('div');
        flake.classList.add('snowflake');
        const size = Math.random() * 3 + 1; // 1-4px
        flake.style.width = `${size}px`;
        flake.style.height = `${size}px`;
        flake.style.left = `${Math.random() * 100}%`;
        flake.style.top = `-50px`; // 确保初始位置在屏幕外
        const duration = Math.random() * 20 + 20;
        flake.style.animationDuration = `${duration}s`; // 20-40s
        flake.style.animationDelay = `${-Math.random() * duration}s`; // 从不同下落阶段开始
        container.appendChild(flake);
      }
    }
  </script>
</html>

<style>
  body {
    display: grid;
    grid-template-columns: 280px 1fr;
    min-height: 100vh;
    margin: 0;
    overflow-x: hidden; /* 防止侧边栏引起的水平溢出 */
  }
  .sidebar-shell {
    min-width: 0;
  }
  main {
    padding: 20px;
    width: 100%;
    min-width: 0;
    display: flex;
    flex-direction: column;
    flex: 1; /* 强制占满剩余空间 */
  }
  :global(::view-transition-old(page-content)) {
    animation: content-sink 300ms cubic-bezier(0.4, 0, 1, 1) both;
  }
  :global(::view-transition-new(page-content)) {
    animation: content-rise 300ms cubic-bezier(0, 0, 0.2, 1) both;
  }
  :global(::view-transition-old(root)),
  :global(::view-transition-new(root)) {
    animation: none;
  }
  @keyframes content-sink {
    to {
      opacity: 0;
      transform: translateY(20px);
    }
  }
  @keyframes content-rise {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(::view-transition-old(page-content)),
    :global(::view-transition-new(page-content)) {
      animation-duration: 1ms;
    }
  }
  @media (max-width: 768px) {
    body {
      grid-template-columns: 1fr;
    }
    main {
      padding: 72px 28px 28px;
    }
  }
</style>
