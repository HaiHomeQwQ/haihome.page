---
export interface Props {
  title: string;
}

const { title } = Astro.props;
import '../styles/global.css';
import '../fonts/xiaolai/xiaolai.css';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
      <div class="background-animation"></div>
      <Sidebar />
      <main>
        <slot />
        <Footer />
      </main>
      <Analytics />
      <SpeedInsights />
  </body>
  <script>
    const container = document.querySelector('.background-animation');
    if (container) {
      const count = 50;
      for (let i = 0; i < count; i++) {
        const flake = document.createElement('div');
        flake.classList.add('snowflake');
        const size = Math.random() * 3 + 1; // 1-4px
        flake.style.width = `${size}px`;
        flake.style.height = `${size}px`;
        flake.style.left = `${Math.random() * 100}%`;
        flake.style.top = `-50px`; // 确保初始位置在屏幕外
        flake.style.animationDuration = `${Math.random() * 20 + 20}s`; // 20-40s
        flake.style.animationDelay = `${Math.random() * 30}s`; // 初始分散延迟
        container.appendChild(flake);
      }
    }
  </script>
</html>

<style>
  body {
    display: grid;
    grid-template-columns: 280px 1fr;
    min-height: 100vh;
    margin: 0;
    overflow-x: hidden; /* 防止侧边栏引起的水平溢出 */
  }
  main {
    padding: 20px;
    width: 100%;
    min-width: 0; /* 允许 flex/grid 子项缩小 */
  }
  @media (max-width: 768px) {
    body {
      grid-template-columns: 1fr;
    }
    main {
      padding: 72px 28px 28px;
    }
  }
</style>
